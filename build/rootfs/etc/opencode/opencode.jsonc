{
    "$schema": "https://opencode.ai/config.json",

    "theme": "github",

    "permission": {
        "edit": "ask",
        "write": "ask",
        "bash": "ask"
    },

    "autoupdate": false,

    "share": "manual",

    "compaction": {
        "auto": true,
        "prune": true,
        "reserved": 10000
    },

    "watcher": {
        "ignore": [
            ".git/**",
            "node_modules/**",
            "dist/**",
            "build/**"
        ]
    }
}
