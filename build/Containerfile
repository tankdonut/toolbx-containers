ARG FEDORA_VERSION

# hadolint ignore=DL3007
FROM ghcr.io/tankdonut/tools@sha256:2e57dba4a8614abeefa6b40cc0058cfa312b59e58e5132495303f0e96eee4c0a as tools

FROM quay.io/fedora/fedora-toolbox:${FEDORA_VERSION}

ARG FEDORA_VERSION

# hadolint ignore=SC2046,DL3016,DL3041
RUN dnf install -y "https://download1.rpmfusion.org/free/fedora/rpmfusion-free-release-${FEDORA_VERSION}.noarch.rpm" \
    "https://download1.rpmfusion.org/nonfree/fedora/rpmfusion-nonfree-release-${FEDORA_VERSION}.noarch.rpm" && \
    dnf clean all

COPY fedora-packages.txt /vendor/

COPY rootfs/etc/yum.repos.d/ /etc/yum.repos.d/

# hadolint ignore=SC2046,DL3016,DL3041
RUN dnf install -y $(awk '!/^($|#)/ { print $1 }' /vendor/fedora-packages.txt) && \
    dnf clean all

# https://librewolf.net/installation/fedora/
# hadolint ignore=DL3041
RUN dnf copr enable -y bgstack15/AfterMozilla && \
    dnf install --refresh -y librewolf && \
    dnf clean all

# hadolint ignore=DL3041
RUN dnf install -y libxshmfence && \
    dnf install -y codium && \
    dnf clean all

RUN curl -sSL -o /tmp/bun.zip "https://github.com/oven-sh/bun/releases/latest/download/bun-linux-x64.zip" && \
    unzip /tmp/bun.zip -d /tmp/bun && \
    mv /tmp/bun/bun-linux-x64/bun /usr/local/bin/ && \
    chmod +x /usr/local/bin/bun && \
    ln -s /usr/local/bin/bun /usr/local/bin/bunx && \
    rm -rf /tmp/bun.zip /tmp/bun

RUN ln -sf /usr/bin/host-spawn /usr/local/bin/buildah && \
    ln -sf /usr/bin/host-spawn /usr/local/bin/docker && \
    ln -sf /usr/bin/host-spawn /usr/local/bin/docker-compose && \
    ln -sf /usr/bin/host-spawn /usr/local/bin/flatpak && \
    ln -sf /usr/bin/host-spawn /usr/local/bin/podman && \
    ln -sf /usr/bin/host-spawn /usr/local/bin/podman-compose && \
    ln -sf /usr/bin/host-spawn /usr/local/bin/rpm-ostree

# hadolint ignore=DL3016,DL3059
RUN npm install -g playwright && \
    ln -sf /usr/bin/chromium-browser /usr/bin/chromium && \
    mkdir -p /opt/google/chrome && \
    ln -sf /usr/bin/chromium-browser /opt/google/chrome/chrome

COPY rootfs/usr/share/fonts/ /usr/share/fonts/

RUN fc-cache -f

COPY rootfs/ /

COPY --from=tools /dist/ /vendor/bin/

# add python, node, and packages bin to PATH
ENV PATH="/vendor/bin:/vendor/python/bin:/vendor/node_modules/.bin:${PATH}"

ENV WORKSPACE="${HOME}/Development"
